# Inject Auto-Bullet Javascript for textareas
st.html(
    """
    <div style="display:none"></div>
    <script>
    const doc = window.parent.document;
    if (!doc.getElementById("auto-bullet-script")) {
        const script = doc.createElement("script");
        script.id = "auto-bullet-script";
        script.innerHTML = `
            function pushValueToStreamlit(textarea, value, caretPos) {
                let nativeInputValueSetter = Object.getOwnPropertyDescriptor(window.HTMLTextAreaElement.prototype, "value").set;
                nativeInputValueSetter.call(textarea, value);
                textarea.selectionStart = textarea.selectionEnd = caretPos;
                textarea.dispatchEvent(new Event("input", { bubbles: true }));
            }

            document.addEventListener("keydown", function(e) {
                if (e.target.tagName === "TEXTAREA" && e.key === "Enter") {
                    const val = e.target.value;
                    const start = e.target.selectionStart;
                    const end = e.target.selectionEnd;
                    
                    const textBeforeCursor = val.substring(0, start);
                    const lastNewLine = textBeforeCursor.lastIndexOf("\\n");
                    const currentLine = textBeforeCursor.substring(lastNewLine + 1);
                    
                    const bulletMatch = currentLine.match(/^(\\s*[-*•]\\s+)/);
                    if (bulletMatch) {
                        if (currentLine.trim() === bulletMatch[1].trim()) {
                            e.preventDefault();
                            const lineStart = lastNewLine !== -1 ? lastNewLine + 1 : 0;
                            const updatedValue = val.substring(0, lineStart) + val.substring(end);
                            pushValueToStreamlit(e.target, updatedValue, lineStart);
                            return;
                        }

                        e.preventDefault();
                        const bullet = bulletMatch[1];
                        const newText = "\\n" + bullet;
                        const updatedValue = val.substring(0, start) + newText + val.substring(end);
                        pushValueToStreamlit(e.target, updatedValue, start + newText.length);
                        return;
                    }

                    if (currentLine.trim() !== "") {
                        e.preventDefault();
                        const newText = "\\n- ";
                        const updatedValue = val.substring(0, start) + newText + val.substring(end);
                        pushValueToStreamlit(e.target, updatedValue, start + newText.length);
                    }
                }
            });
        `;
        doc.body.appendChild(script);
    }
    </script>
    """,
    width="content",
    unsafe_allow_javascript=True
)

BACKEND_SYNC_STATE_PATH = "data/backend_sync_state.json"
SYNC_CLOCK_SKEW_SECONDS = 2
SYSTEM_DATA_FOLDER_NAME = "System Data"
PLANNED_MILESTONE_SNAPSHOT_PATH = "data/planned_milestones.json"
PLANNED_MILESTONE_RECORD_PREFIX = "planned_milestone_record_"
PLANNED_MILESTONE_AUDIT_LOG_PATH = "data/planned_milestone_audit.jsonl"
SHARED_DATA_AUDIT_LOG_PATH = "data/shared_data_audit.jsonl"
PROTECTED_SYSTEM_DATA_FILE_NAMES = {
    "tasks.xlsx",
    "project_notes.json",
    "drive_metadata.json",
    "competitors.xlsx",
    os.path.basename(SHARED_DATA_AUDIT_LOG_PATH),
}
CONFLICT_RESOLUTION_STATE_KEY = "pending_conflict_resolution"
CONFLICT_RESOLUTION_NOTICE_KEY = "pending_conflict_resolution_notice"


def _utc_now_iso():
    return datetime.utcnow().replace(microsecond=0).isoformat() + "Z"


def _normalize_sync_path(local_path):
    return os.path.normpath(local_path)


def _is_non_blocking_drive_sync_path(local_path):
    file_name = os.path.basename(str(local_path or "").strip())
    return file_name in {
        "daily_activity.log",
        os.path.basename(SHARED_DATA_AUDIT_LOG_PATH),
        os.path.basename(PLANNED_MILESTONE_AUDIT_LOG_PATH),
        os.path.basename(BACKEND_SYNC_STATE_PATH),
    }


def _is_drive_storage_quota_error(exc):
    message = str(exc or "")
    return "storageQuotaExceeded" in message or "Service Accounts do not have storage quota" in message


def load_backend_sync_state():
    if os.path.exists(BACKEND_SYNC_STATE_PATH):
        try:
            with open(BACKEND_SYNC_STATE_PATH, "r") as f:
                data = json.load(f)
                if isinstance(data, dict):
                    return data
        except Exception:
            pass
    return {"files": {}}


def save_backend_sync_state(state):
    os.makedirs("data", exist_ok=True)
    with open(BACKEND_SYNC_STATE_PATH, "w") as f:
        json.dump(state, f, indent=4)


def update_backend_sync_state(local_path, **updates):
    state = load_backend_sync_state()
    files = state.setdefault("files", {})
    path_key = _normalize_sync_path(local_path)
    entry = files.setdefault(path_key, {})

    for key, value in updates.items():
        if value is not None:
            entry[key] = value

    if os.path.exists(local_path):
        try:
            entry["last_local_mtime"] = os.path.getmtime(local_path)
        except OSError:
            pass

    save_backend_sync_state(state)
    return entry


def mark_backend_file_dirty(local_path):
    update_backend_sync_state(
        local_path,
        pending_upload=True,
        local_saved_at=_utc_now_iso(),
        last_upload_error=None,
    )


def _is_planned_milestone_drive_name(file_name):
    file_name = str(file_name or "").strip()
    if file_name == "":
        return False
    return (
        file_name == os.path.basename(PLANNED_MILESTONE_SNAPSHOT_PATH)
        or file_name == os.path.basename(PLANNED_MILESTONE_AUDIT_LOG_PATH)
        or file_name.startswith(PLANNED_MILESTONE_RECORD_PREFIX)
    )


def _is_planned_milestone_sync_path(local_path):
    normalized = _normalize_sync_path(local_path)
    return _is_planned_milestone_drive_name(os.path.basename(normalized))


def _is_protected_system_data_drive_name(file_name):
    file_name = str(file_name or "").strip()
    if file_name == "":
        return False
    return file_name in PROTECTED_SYSTEM_DATA_FILE_NAMES or _is_planned_milestone_drive_name(file_name)


def _is_protected_system_data_sync_path(local_path):
    normalized = _normalize_sync_path(local_path)
    return _is_protected_system_data_drive_name(os.path.basename(normalized))


def _get_planned_milestone_actor():
    actor_name = str(st.session_state.get("auth_name") or "Unknown User").strip() or "Unknown User"
    actor_role = str(st.session_state.get("role") or "Unknown Role").strip() or "Unknown Role"
    return actor_name, actor_role


def queue_conflict_resolution(scope, message):
    st.session_state[CONFLICT_RESOLUTION_STATE_KEY] = {
        "scope": str(scope or "").strip() or "shared",
        "message": str(message or "").strip() or "Conflict detected. Refresh and save again.",
        "queued_at": _utc_now_iso(),
    }


def _run_conflict_resolution_refresh(scope):
    scope = str(scope or "").strip()
    if scope == "milestones":
        return pull_backend_data_from_drive(
            file_name_filter=_is_planned_milestone_drive_name,
            log_result=False,
        )
    return pull_backend_data_from_drive(
        file_name_filter=_is_protected_system_data_drive_name,
        log_result=False,
    )


def _clear_all_milestone_edit_version_state():
    keys_to_remove = [
        key for key in st.session_state.keys()
        if key.endswith("__base_version") or key.endswith("__record_id")
    ]
    for key in keys_to_remove:
        st.session_state.pop(key, None)


def render_conflict_resolution_panel():
    notice = str(st.session_state.get(CONFLICT_RESOLUTION_NOTICE_KEY, "")).strip()
    if notice:
        st.info(notice)
        st.session_state.pop(CONFLICT_RESOLUTION_NOTICE_KEY, None)

    conflict_state = st.session_state.get(CONFLICT_RESOLUTION_STATE_KEY)
    if not isinstance(conflict_state, dict):
        return

    message = str(conflict_state.get("message", "")).strip() or (
        "Conflict detected. Refresh latest data and save again."
    )
    st.warning(
        message + " Use `Refresh Latest + Keep My Entries` so the newest shared data loads without clearing the values you already typed."
    )
    action_col1, action_col2 = st.columns([2, 1])
    if action_col1.button("Refresh Latest + Keep My Entries", key="conflict_refresh_keep_entries"):
        refreshed = _run_conflict_resolution_refresh(conflict_state.get("scope"))
        if str(conflict_state.get("scope", "")).strip() == "milestones":
            _clear_all_milestone_edit_version_state()
        if refreshed:
            st.session_state[CONFLICT_RESOLUTION_NOTICE_KEY] = (
                "Latest shared data was refreshed. Your current form entries were kept; review the latest values and save again."
            )
        else:
            st.session_state[CONFLICT_RESOLUTION_NOTICE_KEY] = (
                "Refresh could not complete, but your current entries are still kept in the form."
            )
        st.session_state.pop(CONFLICT_RESOLUTION_STATE_KEY, None)
        st.rerun()
    if action_col2.button("Dismiss", key="conflict_dismiss"):
        st.session_state.pop(CONFLICT_RESOLUTION_STATE_KEY, None)
        st.rerun()


def _append_shared_data_audit_entry(local_path, action, details=None):
    os.makedirs("data", exist_ok=True)
    actor_name, actor_role = _get_planned_milestone_actor()
    entry = {
        "timestamp": _utc_now_iso(),
        "action": str(action or "").strip() or "save",
        "file_name": os.path.basename(str(local_path or "").strip()),
        "local_path": _normalize_sync_path(local_path),
        "actor_name": actor_name,
        "actor_role": actor_role,
        "details": details if isinstance(details, dict) else {},
    }
    with open(SHARED_DATA_AUDIT_LOG_PATH, "a") as f:
        f.write(json.dumps(entry) + "\n")
    mark_backend_file_dirty(SHARED_DATA_AUDIT_LOG_PATH)
    sync_data_file_to_drive(SHARED_DATA_AUDIT_LOG_PATH)


def _append_planned_milestone_audit_entry(action, milestone_name, before_info=None, after_info=None, record_id="", version=None, deleted=False):
    os.makedirs("data", exist_ok=True)
    actor_name, actor_role = _get_planned_milestone_actor()
    entry = {
        "timestamp": _utc_now_iso(),
        "action": str(action or "").strip() or "update",
        "milestone_id": str(milestone_name or "").strip(),
        "record_id": str(record_id or "").strip(),
        "version": int(version) if version is not None else None,
        "deleted": bool(deleted),
        "actor_name": actor_name,
        "actor_role": actor_role,
        "before": _strip_planned_milestone_meta(before_info) if isinstance(before_info, dict) else {},
        "after": _strip_planned_milestone_meta(after_info) if isinstance(after_info, dict) else {},
    }
    with open(PLANNED_MILESTONE_AUDIT_LOG_PATH, "a") as f:
        f.write(json.dumps(entry) + "\n")
    mark_backend_file_dirty(PLANNED_MILESTONE_AUDIT_LOG_PATH)
    sync_data_file_to_drive(PLANNED_MILESTONE_AUDIT_LOG_PATH)


def _system_data_file_name_filter(file_name):
    file_name = os.path.basename(str(file_name or "").strip())
    return lambda candidate_name: os.path.basename(str(candidate_name or "").strip()) == file_name


def _get_drive_system_data_file(file_name):
    file_name = os.path.basename(str(file_name or "").strip())
    if file_name == "":
        return None
    service = get_google_drive_service()
    if service is None:
        return None
    matching_files = list_system_data_files(service, file_name_filter=_system_data_file_name_filter(file_name))
    if not matching_files:
        return None
    return max(matching_files, key=lambda file_info: str(file_info.get("modifiedTime", "")))


def _shared_file_conflict_message(local_path, remote_modified_time=""):
    file_name = os.path.basename(str(local_path or "").strip()) or str(local_path or "shared file")
    if remote_modified_time:
        return (
            f"Conflict detected for {file_name}. Another user updated the shared file first "
            f"(cloud version at {remote_modified_time}). Refresh the latest data, review it, then save again."
        )
    return (
        f"Conflict detected for {file_name}. The shared cloud version changed and your local copy may be stale. "
        "Refresh the latest data, review it, then save again."
    )


def _prepare_shared_file_save(local_path):
    if not _is_protected_system_data_sync_path(local_path):
        return True, None

    remote_file = _get_drive_system_data_file(os.path.basename(local_path))
    remote_modified_time = str((remote_file or {}).get("modifiedTime", "")).strip()
    sync_entry = load_backend_sync_state().get("files", {}).get(_normalize_sync_path(local_path), {})
    known_drive_modified_time = str(sync_entry.get("last_drive_modified_time", "")).strip()

    if remote_modified_time and known_drive_modified_time and remote_modified_time != known_drive_modified_time:
        pull_backend_data_from_drive(
            file_name_filter=_system_data_file_name_filter(local_path),
            log_result=False,
        )
        message = _shared_file_conflict_message(local_path, remote_modified_time)
        queue_conflict_resolution("shared", message)
        return False, message

    if remote_modified_time and not known_drive_modified_time and os.path.exists(local_path):
        pull_backend_data_from_drive(
            file_name_filter=_system_data_file_name_filter(local_path),
            log_result=False,
        )
        message = _shared_file_conflict_message(local_path, remote_modified_time)
        queue_conflict_resolution("shared", message)
        return False, message

    return True, None


def _planned_milestone_record_path(record_id):
    return os.path.join("data", f"{PLANNED_MILESTONE_RECORD_PREFIX}{record_id}.json")


def _strip_planned_milestone_meta(mil_info):
    payload = copy.deepcopy(mil_info)
    if isinstance(payload, dict):
        payload.pop("_meta", None)
    return payload


def _get_planned_milestone_meta(mil_info):
    if isinstance(mil_info, dict):
        meta = mil_info.get("_meta", {})
        if isinstance(meta, dict):
            return meta
    return {}


def get_planned_milestone_version(mil_info):
    try:
        return int(_get_planned_milestone_meta(mil_info).get("version", 0) or 0)
    except (TypeError, ValueError):
        return 0


def get_planned_milestone_record_id(mil_info):
    return str(_get_planned_milestone_meta(mil_info).get("record_id", "")).strip()


def _annotate_planned_milestone(milestone_name, payload, record_id, version, updated_at, storage):
    annotated = _strip_planned_milestone_meta(payload)
    annotated["_meta"] = {
        "milestone_id": milestone_name,
        "record_id": record_id,
        "version": int(version),
        "updated_at": updated_at,
        "storage": storage,
    }
    return annotated


def _planned_milestone_conflict_message(milestone_name, latest_info):
    latest_meta = _get_planned_milestone_meta(latest_info)
    updated_at = latest_meta.get("updated_at", "unknown time")
    version = latest_meta.get("version", "?")
    return (
        f"Conflict detected for {milestone_name}. Another user updated it first "
        f"(version {version}, updated {updated_at}). Refresh the latest data, review the newest values, then save again."
    )


def _write_planned_milestone_record(record_id, milestone_name, payload, version, deleted=False):
    os.makedirs("data", exist_ok=True)
    record_path = _planned_milestone_record_path(record_id)
    record_data = {
        "record_id": record_id,
        "milestone_id": milestone_name,
        "version": int(version),
        "updated_at": _utc_now_iso(),
        "deleted": bool(deleted),
        "data": {} if deleted else _strip_planned_milestone_meta(payload),
    }
    with open(record_path, "w") as f:
        json.dump(record_data, f, indent=4)
    mark_backend_file_dirty(record_path)
    sync_data_file_to_drive(record_path)
    return record_data


def _write_planned_milestone_snapshot(milestones):
    snapshot = {
        milestone_name: _strip_planned_milestone_meta(mil_info)
        for milestone_name, mil_info in milestones.items()
    }
    os.makedirs("data", exist_ok=True)
    with open(PLANNED_MILESTONE_SNAPSHOT_PATH, "w") as f:
        json.dump(snapshot, f, indent=4)
    mark_backend_file_dirty(PLANNED_MILESTONE_SNAPSHOT_PATH)
    sync_data_file_to_drive(PLANNED_MILESTONE_SNAPSHOT_PATH)


def _load_planned_milestone_snapshot():
    if os.path.exists(PLANNED_MILESTONE_SNAPSHOT_PATH):
        try:
            with open(PLANNED_MILESTONE_SNAPSHOT_PATH, "r") as f:
                data = json.load(f)
                if isinstance(data, dict):
                    return data
        except Exception:
            pass
    return {}


def _load_planned_milestone_records():
    record_paths = glob.glob(os.path.join("data", f"{PLANNED_MILESTONE_RECORD_PREFIX}*.json"))
    latest_by_name = {}

    for record_path in record_paths:
        try:
            with open(record_path, "r") as f:
                record = json.load(f)
        except Exception:
            continue

        milestone_name = str(record.get("milestone_id", "")).strip()
        if milestone_name == "":
            continue

        try:
            version = int(record.get("version", 0) or 0)
        except (TypeError, ValueError):
            version = 0

        current = latest_by_name.get(milestone_name)
        if current is None or version >= current.get("version", 0):
            latest_by_name[milestone_name] = {
                "record_id": str(record.get("record_id", "")).strip(),
                "version": version,
                "updated_at": record.get("updated_at", ""),
                "deleted": bool(record.get("deleted", False)),
                "data": record.get("data", {}),
            }

    return latest_by_name


def load_planned_milestones():
    record_entries = _load_planned_milestone_records()
    milestones = {}
    tombstoned_names = set()

    for milestone_name, record in record_entries.items():
        if record.get("deleted"):
            tombstoned_names.add(milestone_name)
            continue
        payload = record.get("data", {})
        if not isinstance(payload, dict):
            payload = {}
        milestones[milestone_name] = _annotate_planned_milestone(
            milestone_name,
            payload,
            record.get("record_id") or str(uuid.uuid4()),
            record.get("version", 1),
            record.get("updated_at", ""),
            "record",
        )

    snapshot_mtime = None
    if os.path.exists(PLANNED_MILESTONE_SNAPSHOT_PATH):
        try:
            snapshot_mtime = datetime.fromtimestamp(os.path.getmtime(PLANNED_MILESTONE_SNAPSHOT_PATH)).strftime("%Y-%m-%d %H:%M:%S")
        except OSError:
            snapshot_mtime = None

    for milestone_name, payload in _load_planned_milestone_snapshot().items():
        if milestone_name in milestones or milestone_name in tombstoned_names:
            continue
        if not isinstance(payload, dict):
            continue
        milestones[milestone_name] = _annotate_planned_milestone(
            milestone_name,
            payload,
            f"legacy::{milestone_name}",
            1,
            snapshot_mtime or "legacy snapshot",
            "legacy_snapshot",
        )

    return milestones


def save_planned_milestone_entry(milestone_name, mil_info, expected_version=None, previous_name=None):
    milestone_name = str(milestone_name or "").strip()
    previous_name = str(previous_name or milestone_name).strip()
    if milestone_name == "":
        return False, "Please provide a milestone name."

    pull_backend_data_from_drive(file_name_filter=_is_planned_milestone_drive_name, log_result=False)
    current_data = load_planned_milestones()
    current_info = current_data.get(previous_name)
    current_version = get_planned_milestone_version(current_info)

    if expected_version is not None and current_version != int(expected_version):
        message = _planned_milestone_conflict_message(previous_name, current_info)
        queue_conflict_resolution("milestones", message)
        return False, message

    if milestone_name != previous_name and milestone_name in current_data:
        return False, "A milestone with this name already exists. Please choose a different name."

    record_id = get_planned_milestone_record_id(current_info) or get_planned_milestone_record_id(mil_info)
    if record_id == "" or record_id.startswith("legacy::"):
        record_id = str(uuid.uuid4())

    next_version = max(current_version, 0) + 1
    record_data = _write_planned_milestone_record(record_id, milestone_name, mil_info, next_version, deleted=False)
    saved_info = _annotate_planned_milestone(
        milestone_name,
        mil_info,
        record_id,
        next_version,
        record_data.get("updated_at", _utc_now_iso()),
        "record",
    )

    if previous_name != milestone_name and previous_name in current_data:
        _write_planned_milestone_record(str(uuid.uuid4()), previous_name, {}, next_version, deleted=True)
        del current_data[previous_name]
    current_data[milestone_name] = saved_info
    _write_planned_milestone_snapshot(current_data)
    _append_planned_milestone_audit_entry(
        action="save",
        milestone_name=milestone_name,
        before_info=current_info,
        after_info=saved_info,
        record_id=record_id,
        version=next_version,
        deleted=False,
    )
    log_activity(f"Updated planned milestone {milestone_name}")
    return True, saved_info


def delete_planned_milestone_entry(milestone_name, expected_version=None):
    milestone_name = str(milestone_name or "").strip()
    pull_backend_data_from_drive(file_name_filter=_is_planned_milestone_drive_name, log_result=False)
    current_data = load_planned_milestones()
    current_info = current_data.get(milestone_name)
    if current_info is None:
        return False, f"{milestone_name} was already removed."

    current_version = get_planned_milestone_version(current_info)
    if expected_version is not None and current_version != int(expected_version):
        message = _planned_milestone_conflict_message(milestone_name, current_info)
        queue_conflict_resolution("milestones", message)
        return False, message

    record_id = get_planned_milestone_record_id(current_info)
    if record_id == "" or record_id.startswith("legacy::"):
        record_id = str(uuid.uuid4())

    _write_planned_milestone_record(record_id, milestone_name, {}, current_version + 1, deleted=True)
    del current_data[milestone_name]
    _write_planned_milestone_snapshot(current_data)
    _append_planned_milestone_audit_entry(
        action="delete",
        milestone_name=milestone_name,
        before_info=current_info,
        after_info={},
        record_id=record_id,
        version=current_version + 1,
        deleted=True,
    )
    log_activity(f"Deleted planned milestone {milestone_name}")
    return True, None


def _seed_milestone_edit_version_state(state_key, mil_info):
    version_key = f"{state_key}__base_version"
    record_key = f"{state_key}__record_id"
    current_record_id = get_planned_milestone_record_id(mil_info)
    if (
        version_key not in st.session_state
        or st.session_state.get(record_key) != current_record_id
    ):
        st.session_state[version_key] = get_planned_milestone_version(mil_info)
        st.session_state[record_key] = current_record_id


def _get_milestone_edit_base_version(state_key, mil_info):
    _seed_milestone_edit_version_state(state_key, mil_info)
    return st.session_state.get(f"{state_key}__base_version")


def _clear_milestone_edit_version_state(state_key):
    st.session_state.pop(f"{state_key}__base_version", None)
    st.session_state.pop(f"{state_key}__record_id", None)

# --- EXCEL DATA LAYER ---
@st.cache_data
def load_data(_file_mtime=None):
    file_path = "data/tasks.xlsx"
    legacy_project_names = {
        "Default Project": "Truck Unloading Project",
        "R&D Project": "Truck Unloading Project",
    }
    required_cols = [
        "Project", "Topic", "Task Name", "Start Date", "End Date", 
        "Completion %", "Status", "Employee", "Week", "Hidden",
        "Milestone_Text", "Milestone_Role", "Milestone_Author_Name"
    ]
    if os.path.exists(file_path):
        df = pd.read_excel(file_path)
        needs_save = False
        # Consolidate column defaults and type enforcement into a single loop
        defaults = {
            "Hidden": False, "Completion %": 0, "Week": 1, 
            "Project": "R&D Project", "Employee": "Unassigned",
            "Milestone_Role": "None"
        }
        for col in required_cols:
            if col not in df.columns:
                df[col] = defaults.get(col, "")
                needs_save = True

        if "Project" in df.columns:
            normalized_projects = df["Project"].replace(legacy_project_names)
            if not normalized_projects.equals(df["Project"]):
                df["Project"] = normalized_projects
                needs_save = True
        df["Hidden"] = df["Hidden"].fillna(False).astype(bool)
        if needs_save:
            os.makedirs("data", exist_ok=True)
            df.to_excel(file_path, index=False)
        return df
    return pd.DataFrame(columns=required_cols)

def save_data(data_df):
    save_ok, message = _prepare_shared_file_save("data/tasks.xlsx")
    if not save_ok:
        st.error(message)
        return False
    os.makedirs("data", exist_ok=True)
    data_df.to_excel("data/tasks.xlsx", index=False)
    mark_backend_file_dirty("data/tasks.xlsx")
    sync_data_file_to_drive("data/tasks.xlsx")
    _append_shared_data_audit_entry(
        "data/tasks.xlsx",
        "save",
        {"rows": int(len(data_df.index)), "columns": [str(c) for c in data_df.columns]},
    )
    log_activity("Updated tasks.xlsx")
    st.cache_data.clear()  # Ensure the next load reflects the newly saved data
    return True

def load_notes():
    if os.path.exists("data/project_notes.json"):
